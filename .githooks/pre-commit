#!/usr/bin/env bash
# Pre-commit hook: R syntax + YAML validation on staged files.
# If the required tools aren't on PATH, re-executes inside the nix dev shell.
set -euo pipefail

if ! command -v Rscript &>/dev/null || ! command -v yq &>/dev/null; then
  exec nix develop "path:$(git rev-parse --show-toplevel)/tests" --command "$0" "$@"
fi

PASS=0

# Staged files that are being added/modified (not deleted)
staged() { git diff --cached --name-only --diff-filter=ACM "$@"; }

# ── R syntax ──────────────────────────────────────────────────────────────────
r_files=$(staged | grep -E '\.(R|Rmd)$' || true)
if [[ -n "$r_files" ]]; then
  if ! command -v Rscript &>/dev/null; then
    echo "⚠  Rscript not found — skipping R syntax check (enter nix shell first)"
  else
    echo "Checking R syntax..."
    while IFS= read -r f; do
      if Rscript --vanilla -e "tryCatch(parse('$f'), error=function(e) stop(conditionMessage(e)))" \
           2>&1 | grep -q "Error"; then
        echo "  ✗ R syntax error: $f"
        PASS=1
      else
        echo "  ✓ $f"
      fi
    done <<< "$r_files"
  fi
fi

# ── YAML validation ───────────────────────────────────────────────────────────
yml_files=$(staged | grep -E '\.yml$' || true)
if [[ -n "$yml_files" ]]; then
  if ! command -v yq &>/dev/null; then
    echo "⚠  yq not found — skipping YAML check (enter nix shell first)"
  else
    echo "Checking YAML syntax..."
    while IFS= read -r f; do
      if yq e '.' "$f" > /dev/null 2>&1; then
        echo "  ✓ $f"
      else
        echo "  ✗ YAML error: $f"
        yq e '.' "$f" 2>&1 | sed 's/^/    /'
        PASS=1
      fi
    done <<< "$yml_files"
  fi
fi

exit $PASS
